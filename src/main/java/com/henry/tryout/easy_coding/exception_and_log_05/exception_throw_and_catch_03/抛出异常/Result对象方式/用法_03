第二步：在 Controller 中使用
Controller 的方法返回值 不再是 具体的User或List，而是 Result<User> 或 Result<List>。
@RestController
@RequestMapping("/users")
public class UserController {

    @Autowired
    private UserService userService;

    // 场景 1：查询单个用户
    @GetMapping("/{id}")
    public Result<User> getUser(@PathVariable Long id) {
        User user = userService.findById(id);
        if (user == null) {
            // 返回业务错误
            return Result.error(40001, "用户不存在");
        }
        // 返回成功数据
        return Result.success(user);
    }

    // 场景 2：新增用户
    @PostMapping
    public Result<Long> createUser(@RequestBody User user) {
        try {
            Long newId = userService.create(user);
            return Result.success(newId); // 返回生成的 ID
        } catch (IllegalArgumentException e) {
            // 参数校验失败
            return Result.error(40002, e.getMessage());
        }
    }

    // 场景 3：删除用户 (无返回值)
    @DeleteMapping("/{id}")
    public Result<Void> deleteUser(@PathVariable Long id) {
        userService.delete(id);
        return Result.success(); // data 为 null
    }
}

