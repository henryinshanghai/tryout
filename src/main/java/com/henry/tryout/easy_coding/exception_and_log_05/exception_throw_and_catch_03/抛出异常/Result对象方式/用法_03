第四步：前端如何处理
前端（如 Vue/React + Axios）设置 响应拦截器：

// axios 拦截器
axios.interceptors.response.use(response => {
  const res = response.data;

  // 假设约定 code 200 为成功
  if (res.code !== 200) {
    // 统一处理错误
    Message.error(res.message || 'Error');

    // 特殊错误码 处理，例如 401 跳登录
    if (res.code === 401) {
      location.href = '/login';
    }

    return Promise.reject(new Error(res.message));
  } else {
    // 成功，直接返回 data部分，组件里 就不用再写 res.data.data 了
    return res.data;
  }
});

